	"accessWidener" : "cataclysm.accesswidener",
	"depends": {
		"fabricloader": ">=0.16.10",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*",
		"trinkets": ">=3.10.0",
		"forgeconfigapiport": ">=21.1.3",
		"styled-boss-bar-api": ">=0.0.4"
	},
	"suggests": {
	}
