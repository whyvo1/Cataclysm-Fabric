{
	"schemaVersion": 1,
	"id": "cataclysm",
	"version": "${version}",
	"name": "Cataclysm (Fabric)",
	"description": "Fabric port of L_Ender's Cataclysm",
	"authors": [
		"Whyvo",
		"L_Ender & all contributors of Cataclysm"
	],
	"contact": {
	},
	"license": "MIT License",
	"icon": "assets/cataclysm/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.github.l_ender.cataclysm.Cataclysm"
		],
		"client":[
			"com.github.l_ender.cataclysm.CataclysmClient"
		],
		"jei_mod_plugin": [
			"com.github.l_ender.cataclysm.jei.LEnderCataclysmJEIPlugin"
		]
	},
	"mixins": [
		"cataclysm.mixins.json"
	],
	"custom": {
